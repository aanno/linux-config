# Config for OpenVPN 2.x

setenv IV_GUI_VER "de.blinkt.openvpn 0.7.51"
setenv IV_SSO openurl,webauth,crtext
setenv IV_PLAT_VER "30 11 arm64-v8a OnePlus msm8996 ONEPLUS A3003"
setenv IV_HWADDR 35:36:65:66:32:62:37
tls-cert-profile preferred
machine-readable-output
allow-recursive-routing
ifconfig-nowarn
client
verb 3
connect-retry 2 300
resolv-retry 60
dev tun
# uk-lon2-smart.serverlocation.co has address 92.119.176.194
remote 92.119.176.194 1194 udp
