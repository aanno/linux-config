redirect-gateway autolocal
pull-filter ignore redirect-gateway
pull-filter ignore "route 0.0.0.0"
pull-filter ignore "route 128.0.0.0"
key-direction 1
route 54.93.169.181  255.255.255.255 vpn_gateway
route 212.71.249.225  255.255.255.255 vpn_gateway
# This DNS enty seems to be wrong (aanno)
# dhcp-option DNS 54.93.169.181
dhcp-option DNS 212.71.249.225
dhcp-option DOMAIN getflix.com
nobind
remote-cert-tls server
data-ciphers AES-256-GCM:AES-128-GCM:CHACHA20-POLY1305:AES-256-CBC
cipher AES-256-CBC
auth SHA256
persist-key
persist-tun
# persist-tun also enables pre resolving to avoid DNS resolve problem
preresolve
# Use system proxy setting
# Custom configuration options
# You are on your on own here :)
# These options found in the config file do not map to config settings:
keepalive 60 120
resolv-retry infinite
auth-nocache
# user nobody
# group nobody

# The following seems to be needed by linux ONLY (aanno)
# Lower effective packet size to avoid fragmentation
mssfix 1300
# Optional: if you see UDP/MTU warnings in the log, also add:
tun-mtu 1500
# or, if you suspect tight paths:
# tun-mtu 1420
# This configuration only redirect ipv4. To have real VPN, you must disable ipv6!
# sudo sysctl -w net.ipv6.conf.all.disable_ipv6=1
